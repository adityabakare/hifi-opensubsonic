# Database
POSTGRES_USER=subsonic
POSTGRES_PASSWORD=subsonic
POSTGRES_DB=subsonic

# JWT Authentication (generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-to-a-strong-random-secret

# Upstream instances (auto-fetched from monochrome by default; override URL if needed)
# MONOCHROME_INSTANCES_URL=https://raw.githubusercontent.com/monochrome-music/monochrome/main/public/instances.json

# Last.fm API Keys
LASTFM_API_KEY=your-api-key-here
LASTFM_API_SECRET=your-api-secret-here

# Filter explicit content: All, Clean, Explicit
EXPLICIT_CONTENT_FILTER=All

# Subsonic Token Encryption (REQUIRED)
# Generate a 32-byte base64 key: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your-fernet-key-here
