# === Database ===
POSTGRES_USER=subsonic
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=subsonic

# === Security ===
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME

# Generate: python3 -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
TOKEN_ENCRYPTION_KEY=CHANGE_ME

# Set to false if serving over plain HTTP (e.g. home network without TLS)
COOKIE_SECURE=true

# Allow anyone to register via the web UI (set to true to enable)
ALLOW_PUBLIC_REGISTRATION=false

# === Optional ===
# Last.fm scrobbling (leave blank to disable)
LASTFM_API_KEY=
LASTFM_API_SECRET=

# Content filtering: All, Clean, Explicit
EXPLICIT_CONTENT_FILTER=All

# Port the app listens on (used by docker-compose)
HIFI_PORT=8000
