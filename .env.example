# Database
POSTGRES_USER=subsonic
POSTGRES_PASSWORD=subsonic
POSTGRES_DB=subsonic

# JWT Authentication (generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-to-a-strong-random-secret

# Upstream hifi-api instances (JSON array)
HIFI_INSTANCES=["https://example-api-1.com","https://example-api-2.com"]

# Last.fm API Keys
LASTFM_API_KEY=your-api-key-here
LASTFM_API_SECRET=your-api-secret-here

# Filter explicit content: All, Clean, Explicit
EXPLICIT_CONTENT_FILTER=All
